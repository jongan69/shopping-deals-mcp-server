# Optional broad shopping aggregator. Recommended for the widest coverage.
SERPAPI_API_KEY=

# Optional official eBay Browse API credentials.
# Use either EBAY_ACCESS_TOKEN or EBAY_APP_ID + EBAY_CERT_ID.
EBAY_ACCESS_TOKEN=
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_USE_SANDBOX=false

# Public marketplace/local search defaults.
CRAIGSLIST_SITES=newyork,sfbay,losangeles,chicago,houston

# Optional Facebook Marketplace default search center. You can also pass
# location="latitude,longitude" per tool call.
SHOPPING_FACEBOOK_MARKETPLACE_LATITUDE=
SHOPPING_FACEBOOK_MARKETPLACE_LONGITUDE=
SHOPPING_FACEBOOK_MARKETPLACE_RADIUS_KM=16

# Amazon public HTML search is fragile and may be blocked. Off by default.
SHOPPING_ENABLE_AMAZON_SCRAPE=false

# OfferUp public HTML search is enabled by default and uses inferred/localized results.
SHOPPING_OFFERUP_DEFAULT_CITY=Miami Beach
SHOPPING_OFFERUP_DEFAULT_STATE=FL
SHOPPING_OFFERUP_DEFAULT_ZIP=33139
SHOPPING_OFFERUP_DEFAULT_LATITUDE=25.7907
SHOPPING_OFFERUP_DEFAULT_LONGITUDE=-80.1300
SHOPPING_OFFERUP_RADIUS_MILES=30

# Runtime tuning.
SHOPPING_HTTP_TIMEOUT_SECONDS=15
SHOPPING_MAX_RESULTS_PER_SOURCE=25
SHOPPING_ESTIMATED_TAX_RATE_PERCENT=
SHOPPING_TAX_SHIPPING=true

# Local reseller lead/inventory state for stdio or local HTTP MCP.
SHOPPING_RESALE_STORE_PATH=.shopping-deals/resale-business.json
